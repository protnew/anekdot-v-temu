{
  "name": "anekdot-v-temu",
  "version": "3.8.0",
  "description": "😂 Анекдот в тему — AI-анекдоты по контексту",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build-win": "electron-builder --win",
    "build-linux": "electron-builder --linux"
  },
  "build": {
    "appId": "com.anekdot.vtemu",
    "productName": "Анекдот в тему",
    "directories": {
      "output": "../dist-desktop"
    },
    "win": {
      "target": "portable",
      "icon": "icon.ico"
    },
    "linux": {
      "target": "AppImage",
      "icon": "icon.png"
    }
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0"
  }
}
